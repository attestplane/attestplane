{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://attestplane.io/schemas/cli/verify-result-v1.json",
  "title": "Attestplane CLI verify result (v1)",
  "description": "Machine-readable CI-gating output for `attestplane verify --json`.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "result",
    "failed_gates"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "failed_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gate",
          "error_code"
        ],
        "properties": {
          "gate": {
            "type": "string",
            "enum": [
              "non_empty",
              "strict_schema",
              "canonicalization",
              "signature"
            ]
          },
          "error_code": {
            "type": "string",
            "enum": [
              "E_EMPTY_BUNDLE",
              "E_SCHEMA_INVALID",
              "E_CANON_MISMATCH",
              "E_SIGNATURE_INVALID"
            ]
          }
        }
      }
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "vector_id": {
      "type": "string",
      "minLength": 1
    },
    "explanation": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "primary_reason",
          "pointer",
          "message"
        ],
        "properties": {
          "primary_reason": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^att\\.verify\\.[a-z][a-z0-9_]*$"
              },
              {
                "type": "null"
              }
            ]
          },
          "pointer": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
