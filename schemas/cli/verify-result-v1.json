{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://attestplane.io/schemas/cli/verify-result-v1.json",
  "title": "Attestplane CLI verify result (v1)",
  "description": "Machine-readable CI-gating output for `attestplane verify --json`.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "result",
    "exit_code",
    "reason_code",
    "taxonomy_version",
    "reasons",
    "bundle"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "exit_code": {
      "type": "integer",
      "minimum": 0
    },
    "reason_code": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^att\\.verify\\.[a-z][a-z0-9_]*$"
        },
        {
          "type": "null"
        }
      ]
    },
    "taxonomy_version": {
      "type": "integer",
      "const": 1
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "path",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^att\\.verify\\.[a-z][a-z0-9_]*$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "explanation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "anchoring": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "unanchored",
            "pending",
            "anchored",
            "quarantine"
          ]
        },
        "cause": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "explanation": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "primary_reason",
          "pointer",
          "message"
        ],
        "properties": {
          "primary_reason": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^att\\.verify\\.[a-z][a-z0-9_]*$"
              },
              {
                "type": "null"
              }
            ]
          },
          "pointer": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "digest"
      ],
      "properties": {
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
