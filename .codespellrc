[codespell]
skip = .git,LICENSE,DCO.txt,*.lock,_typos.toml,.codespellrc,.lycheeignore,scripts/check-policy.sh
# recuse: legal term ("to disqualify oneself", used in GOVERNANCE.md conflict-of-interest section)
# BaFin: German Federal Financial Supervisory Authority
ignore-words-list = BaFin,attestplane,nd,recuse,recused,recusal
check-hidden = true
