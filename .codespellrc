[codespell]
skip = .git,LICENSE,DCO.txt,*.lock,_typos.toml,.codespellrc,.lycheeignore,scripts/check-policy.sh,sdk/typescript/dist
# Keep this list in sync with .github/workflows/ci.yml `ignore_words_list`.
# recuse: legal term ("to disqualify oneself", used in GOVERNANCE.md conflict-of-interest section)
# BaFin: German Federal Financial Supervisory Authority
# intoto / Intoto: in-toto attestation standard (SLSA / Sigstore ecosystem). Appears
# in filenames (`*.intoto.jsonl`) and as a sub-module identifier; not "into".
# afterAll: vitest test-lifecycle API.
# CNA / CNAs: CVE Numbering Authority (MITRE CVE Program term). Not "CAN".
# fpr: GPG colon-format field name for "fingerprint" (gpg --with-colons output;
# also the `<fpr>` placeholder in docs/security/gpg-key-rotation-playbook.md).
# Not the English word "for".
ignore-words-list = BaFin,attestplane,nd,recuse,recused,recusal,intoto,Intoto,afterAll,cna,CNA,CNAs,fpr
check-hidden = true
